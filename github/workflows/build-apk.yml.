name: Build APK
on:
  workflow_dispatch:
    inputs:
      build_id: { required: true, type: string }
      app_name: { required: true, type: string }
      package_id: { required: true, type: string }
      site_url: { required: true, type: string }
      orientation: { required: true, type: string }
      fullscreen: { required: true, type: string }
      tv_support: { required: true, type: string }
      callback_url: { required: true, type: string }
      callback_secret: { required: true, type: string }

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: '20' }
      - uses: actions/setup-java@v4
        with: { distribution: 'temurin', java-version: '17' }

      - name: Install deps
        run: npm install

      - name: Configure app
        env:
          APP_ID: ${{ inputs.package_id }}
          APP_NAME: ${{ inputs.app_name }}
          SITE_URL: ${{ inputs.site_url }}
          ORIENTATION: ${{ inputs.orientation }}
          FULLSCREEN: ${{ inputs.fullscreen }}
          TV_SUPPORT: ${{ inputs.tv_support }}
        run: |
          node scripts/configure.js
          npx cap add android || true
          npx cap sync android

      - name: Apply Android customizations
        run: |
          MANIFEST=android/app/src/main/AndroidManifest.xml
          if [ "${{ inputs.fullscreen }}" = "true" ]; then
            sed -i 's|android:theme="[^"]*"|android:theme="@android:style/Theme.NoTitleBar.Fullscreen"|g' $MANIFEST || true
          fi
          sed -i "s|android:screenOrientation=\"[^\"]*\"|android:screenOrientation=\"${{ inputs.orientation }}\"|g" $MANIFEST || true
          if [ "${{ inputs.tv_support }}" = "true" ]; then
            sed -i 's|<application |<application android:banner="@mipmap/ic_launcher" |' $MANIFEST
            sed -i 's|</application>|<uses-feature android:name="android.software.leanback" android:required="false"/><uses-feature android:name="android.hardware.touchscreen" android:required="false"/></application>|' $MANIFEST
          fi

      - name: Build APK
        working-directory: android
        run: ./gradlew assembleDebug

      - name: Upload APK to callback
        run: |
          curl -X POST "${{ inputs.callback_url }}" \
            -H "x-callback-secret: ${{ inputs.callback_secret }}" \
            -H "x-build-id: ${{ inputs.build_id }}" \
            -H "x-status: success" \
            --data-binary "@android/app/build/outputs/apk/debug/app-debug.apk"

      - name: Notify failure
        if: failure()
        run: |
          curl -X POST "${{ inputs.callback_url }}" \
            -H "x-callback-secret: ${{ inputs.callback_secret }}" \
            -H "x-build-id: ${{ inputs.build_id }}" \
            -H "x-status: failed" \
            -d "Build failed - check Actions logs"
